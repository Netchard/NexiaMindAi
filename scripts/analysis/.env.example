# Configuration requise pour l'analyse de l'index vectoriel (ST-402)
# Copiez ce fichier vers .env et remplissez avec vos valeurs réelles

# URL de votre projet Supabase
# Exemple: https://votre-projet.supabase.co
SUPABASE_URL=

# Clé de service role (admin) - REQUIS pour accéder aux métadonnées de la base
# Cette clé contourne les politiques RLS et a un accès complet
# Trouvable dans: Supabase Dashboard > Settings > API > Service Role Key
SUPABASE_SERVICE_ROLE_KEY=

# Note: Ne jamais commiter le fichier .env avec les vraies valeurs dans le dépôt git
