# ========================================
# SUPABASE CONFIGURATION
# ========================================

# URL du projet Supabase
# Trouvable dans : Dashboard Supabase → Project Settings → API
SUPABASE_URL=

# Clé anonyme (public) - pour le frontend
# Trouvable dans : Dashboard Supabase → Project Settings → API
SUPABASE_ANON_KEY=

# Clé de service (server-side) - NE JAMAIS EXPOSER EN FRONTEND
# Trouvable dans : Dashboard Supabase → Project Settings → API
SUPABASE_SERVICE_ROLE_KEY=

# ========================================
# MISTRAL AI CONFIGURATION
# ========================================

# Clé API Mistral (pour les embeddings et chat)
# Créez-la sur : https://console.mistral.ai/
MISTRAL_API_KEY=

# URL de base de l'API Mistral (optionnel)
MISTRAL_API_BASE_URL=https://api.mistral.ai/v1/

# Modèle d'embedding
MISTRAL_EMBEDDING_MODEL=mistral-embed

# Modèle de chat
MISTRAL_CHAT_MODEL=mistral-small

# Configuration de la génération
MISTRAL_CHAT_TEMPERATURE=0.7
MISTRAL_CHAT_MAX_TOKENS=2048
MISTRAL_CHAT_TOP_P=0.9

# ========================================
# REDIS / UPSTASH CONFIGURATION
# ========================================

# Configuration Upstash Redis (RECOMMANDÉ pour la production)
# Trouvable dans : Dashboard Upstash → Database → REST URL & Token
UPSTASH_REDIS_REST_URL=https://<region>-<random-id>.upstash.io
UPSTASH_REDIS_REST_TOKEN=

# Configuration Redis locale (optionnelle - pour le développement)
# Lancer Redis localement avec Docker : docker run -p 6379:6379 redis
REDIS_URL=redis://localhost:6379

# ========================================
# APPLICATION CONFIGURATION
# ========================================

# URL de l'application
# Pour le développement local
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Pour la production (exemple)
# NEXT_PUBLIC_APP_URL=https://nexiamind-ai.vercel.app

# ========================================
# OTHER SERVICES (Optionnel)
# ========================================

# GitLab API (optionnel - pour l'indexation)
# GITLAB_API_URL=https://gitlab.com/api/v4
# GITLAB_PRIVATE_TOKEN=

# Nexia GED API (optionnel - pour l'indexation)
# NEXIA_API_URL=https://api.nexia.fr
# NEXIA_API_KEY=

# ========================================
# INSTRUCTIONS
# ========================================
#
# 1. Copiez ce fichier en .env.local
#    cp .env.example .env.local
#
# 2. Remplissez toutes les valeurs nécessaires
#
# 3. NE COMMITEZ JAMAIS .env.local dans Git
#    (Il est dans .gitignore)
#
# 4. Pour le déploiement, configurez ces variables
#    dans votre plateforme (Vercel, Netlify, etc.)
#
# 5. Pour le développement local avec Redis :
#    - Installez Docker
#    - Lancez : docker run -p 6379:6379 redis
#    - Configurez REDIS_URL=redis://localhost:6379
#
# 6. Pour la production avec Upstash :
#    - Créez un compte sur https://upstash.com/
#    - Créez une base de données Redis
#    - Copiez UPSTASH_REDIS_REST_URL et UPSTASH_REDIS_REST_TOKEN
